# PromptMeter Environment Variables
# Copy this to .env.local for local development

# Admin token for viewing waitlist — change this to something long and random!
# Generate one: openssl rand -hex 32
ADMIN_TOKEN=change-me-to-something-secret

# Optional: Add these when you integrate real billing
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Add email service when you outgrow the JSON file approach
# RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG....
